{
  "buildCommand": "cd taxeaseui && npm run build",
  "outputDirectory": "taxeaseui/.next",
  "rootDirectory": ".",
  "env": {
    "NEXT_PUBLIC_BACKEND_URL": "@backend_url"
  },
  "envs": {
    "production": {
      "NEXT_PUBLIC_BACKEND_URL": "@backend_url_prod"
    },
    "preview": {
      "NEXT_PUBLIC_BACKEND_URL": "@backend_url_preview"
    }
  },
  "framework": "nextjs",
  "installCommand": "npm ci"
}
